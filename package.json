{
  "name": "file-compare",
  "displayName": "Branch File Compare",
  "publisher": "Jxsh-6",
  "repository": {
  "type": "git",
  "url": "https://github.com/Jashan66/file-compare"
  },
  "description": "Compare any file against another Git branch, with automatic .ts/.js fallback",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "extensionKind": ["workspace"],
  "contributes": {
    "commands": [
      {
        "command": "file-compare.compareWithBranch",
        "title": "Compare File with Branch",
        "category": "File Compare"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "file-compare.compareWithBranch",
          "when": "!explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "file-compare.compareWithBranch",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
